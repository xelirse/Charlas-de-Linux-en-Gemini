#!/bin/sh

export disco="n"
export iso="iso"
export fci="$disco/$iso"

# Cambiar de ruta al disco de montaje
cd "/$disco"

# Para evitar errores chase
mount -o subvol=@ /dev/sda1 .

# Desmontar sistema del disco
umount "/$disco/"* 2>/dev/null

# Conecta afuera con adentro de chroot.
mkdir -p "/$disco/$iso"
mount --bind "/" "/$disco/$iso"

# Montar /dev
n="dev"
mount --bind "/$n" "/$disco/$n"

# Montar /dev dentro del disco
mount --bind "/$n" "/$disco/$iso/$n"

# Montar proc sin bind (esto resuelve los errores de uuid y boot_id)
n="proc"
mount --bind "/$n" "/$disco/$n"

# Montar sysfs
n="sys"
mount -t "${n}fs" "/$n" "/$disco/$n"

# Forzar copia de entrar hacia afuera de chroot
cp "/$disco/local/bin/entrar" "/bin"

# Entrar
chroot . bash --login
